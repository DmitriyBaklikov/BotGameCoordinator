<!DOCTYPE html>
<html>
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Sport Bot Admin</title>
    <style>
      body { font-family: sans-serif; margin: 0; padding: 0; background: #f5f5f5; }
      nav { background: #2c3e50; color: white; padding: 10px 20px; display: flex; gap: 20px; align-items: center; }
      nav a { color: white; text-decoration: none; }
      nav a:hover { text-decoration: underline; }
      .content { padding: 20px; max-width: 1200px; margin: 0 auto; }
      table { width: 100%; border-collapse: collapse; background: white; }
      th, td { padding: 8px 12px; text-align: left; border-bottom: 1px solid #ddd; }
      th { background: #ecf0f1; font-weight: bold; }
      .btn { display: inline-block; padding: 4px 10px; background: #3498db; color: white; border-radius: 3px; text-decoration: none; font-size: 13px; }
      .btn-danger { background: #e74c3c; }
      .notice { background: #2ecc71; color: white; padding: 10px; margin-bottom: 15px; border-radius: 3px; }
      .badge { display: inline-block; padding: 2px 6px; border-radius: 10px; font-size: 12px; background: #95a5a6; color: white; }
      .badge-active { background: #2ecc71; }
      .badge-cancelled { background: #e74c3c; }
      .badge-archived { background: #95a5a6; }
    </style>
  </head>
  <body>
    <nav>
      <strong>Sport Bot Admin</strong>
      <%= link_to "Games", admin_games_path %>
      <%= link_to "Users", admin_users_path %>
      <%= link_to "Subscriptions", admin_subscriptions_path %>
    </nav>
    <div class="content">
      <% if notice %>
        <div class="notice"><%= notice %></div>
      <% end %>
      <%= yield %>
    </div>
  </body>
</html>
