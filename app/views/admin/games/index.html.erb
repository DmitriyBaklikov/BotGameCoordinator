<h1>Games (<%= Game.count %>)</h1>

<table>
  <thead>
    <tr>
      <th>ID</th>
      <th>Title</th>
      <th>Organizer</th>
      <th>Location</th>
      <th>Scheduled At</th>
      <th>Status</th>
      <th>Visibility</th>
      <th>Participants</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% @games.each do |game| %>
      <tr>
        <td><%= game.id %></td>
        <td><%= game.title %></td>
        <td><%= game.organizer.display_name %></td>
        <td><%= game.location.name %></td>
        <td><%= game.scheduled_at.strftime("%d.%m.%Y %H:%M") %></td>
        <td><span class="badge badge-<%= game.status %>"><%= game.status %></span></td>
        <td><%= game.visibility %></td>
        <td><%= game.game_participants.going.count %>/<%= game.max_participants %></td>
        <td><%= link_to "View", admin_game_path(game), class: "btn" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
